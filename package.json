{
  "name": "nodewitt",
  "version": "0.0.0",
  "description": "Node.js/TypeScript client for Ecowitt weather stations (local poll + push)",
  "license": "MIT",
  "author": "apocaliss92",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apocaliss92/nodewitt.git"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "node --env-file=.env node_modules/vitest/vitest.mjs run --config vitest.e2e.config.ts tests/e2e",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "ecowitt",
    "weather-station",
    "gw1000",
    "gw2000",
    "home-automation",
    "iot"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "undici": "^6.26.0",
    "zod": "^3.25.76"
  }
}
