# nodewitt — example environment for real-device e2e tests.
# Copy to .env and fill in real values. .env is gitignored and must NEVER be committed.

# --- Local poll (Ecowitt GW gateway) ---
# LAN IP/host of the gateway exposing the local HTTP API.
ECOWITT_HOST=
# Local API port (default 80).
ECOWITT_PORT=80
# Optional: gateway password if /set_login_info auth is required (most GW models are open on LAN).
ECOWITT_PASSWORD=

# --- Push listener ---
# Port the push listener binds to (pyecowitt default is 4199). The gateway's
# "Customized" upload server must point at this host:port for push e2e.
ECOWITT_PUSH_PORT=4199

# Gate for the real-device e2e suite. Set to 1 to enable (tests run only on the LAN).
ECOWITT_E2E=0
